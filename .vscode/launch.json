    {
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": ".NET Core Launch (Chrome)",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/bin/Debug/net8.0/YourApp.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false
    },
    {
      "name": "Launch Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "https://localhost:5001/swagger",
      "webRoot": "${workspaceFolder}"
    }
  ]
}